{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp.ReverseProxy": "Debug"
        }
    },
    "AllowedHosts": "*",
    "Jwt": {
        "SecretKey": "mi-clave-secreta-super-segura-de-32-caracteres-minimo-para-jwt-tokens-2024",
        "Issuer": "https://foodies-users-api.onrender.com",
        "Audience": "foodies-api"
    },
    "Keycloak": {
        "Authority": "http://localhost:8080/realms/proyecto-seguro",
        "MetadataAddress": "http://localhost:8080/realms/proyecto-seguro/.well-known/openid-configuration"
    },
    "ReverseProxy": {
      "Routes": {
        "auth-route": {
          "ClusterId": "users-cluster",
          "Match": {
            "Path": "/auth/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/auth/{**catch-all}" }
          ]
        },
        "users-register-route": {
          "ClusterId": "users-cluster",
          "Match": {
            "Path": "/users",
            "Methods": [ "POST" ]
          },
          "Transforms": [
            { "PathPattern": "/api/users" }
          ]
        },
        "api-users-route": {
          "ClusterId": "users-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/api/users/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/users/{**catch-all}" }
          ]
        },
        "users-protected-route": {
          "ClusterId": "users-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/users/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/users/{**catch-all}" }
          ]
        },
        "formulario-foodie-route": {
          "ClusterId": "formulario-foodie-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/formulario-foodie/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/formulariofoodie/{**catch-all}" }
          ]
        },
        "user-info-route": {
          "ClusterId": "formulario-foodie-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/mi-usuario"
          },
          "Transforms": [
            { "PathPattern": "/api/formulariofoodie/mi-usuario" }
          ]
        },
        "reservas-route": {
          "ClusterId": "reservas-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/reservas/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/reservas/{**catch-all}" }
          ]
        },
        "entregables-route": {
          "ClusterId": "reservas-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/entregables/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/entregables/{**catch-all}" }
          ]
        },
        "admincore-route": {
          "ClusterId": "admincore-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/admincore/{**catch-all}"
          },
          "Transforms": [
            { "PathPattern": "/api/{**catch-all}" }
          ]
        },
        "cathering-integration-route": {
          "ClusterId": "reservas-cluster",
          "AuthorizationPolicy": "RequireAuthenticatedUser",
          "Match": {
            "Path": "/integration/cathering",
            "Methods": [ "POST" ]
          },
          "Transforms": [
            { "PathPattern": "/api/integration/cathering" }
          ]
        }
      },
      "Clusters": {
        "users-cluster": {
          "Destinations": {
            "destination1": {
              "Address": "https://foodies-users-api.onrender.com"
            }
          }
        },
        "formulario-foodie-cluster": {
          "Destinations": {
            "destination1": {
              "Address": "https://foodies-formulario-api.onrender.com"
            }
          }
        },
        "reservas-cluster": {
          "Destinations": {
            "destination1": {
              "Address": "https://foodies-reservas-api.onrender.com"
            }
          }
        },
        "admincore-cluster": {
          "Destinations": {
            "destination1": {
              "Address": "https://foodies-admincore-api.onrender.com"
            }
          }
        }
      }
    }
}
