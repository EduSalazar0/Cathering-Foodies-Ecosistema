{
  "realm": "proyecto-seguro",
  "enabled": true,
  "displayName": "Proyecto Seguro Foodies + Cathering",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": true,
      "priority": 10
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrador de seguridad e identidades" },
      { "name": "foodie", "description": "Usuario Foodies" },
      { "name": "restaurante", "description": "Rol operativo de restaurante Foodies" },
      { "name": "estudiante", "description": "Usuario estudiante de Cathering" },
      { "name": "cafeteria", "description": "Operador de cafeteria Cathering" },
      { "name": "personal_academico", "description": "Personal academico Cathering" }
    ],
    "client": {
      "foodies-angular": [
        { "name": "foodies_admin", "description": "Administrador del Sistema B Foodies" },
        { "name": "foodies_foodie", "description": "Usuario consumidor del Sistema B Foodies" },
        { "name": "foodies_restaurante", "description": "Operador restaurante del Sistema B Foodies" }
      ],
      "foodies-backend": [
        { "name": "foodies_admin", "description": "Administrador del Sistema B Foodies" },
        { "name": "foodies_foodie", "description": "Usuario consumidor del Sistema B Foodies" },
        { "name": "foodies_restaurante", "description": "Operador restaurante del Sistema B Foodies" }
      ],
      "cathering-react": [
        { "name": "cathering_admin", "description": "Administrador del Sistema A Cathering" },
        { "name": "cathering_estudiante", "description": "Estudiante del Sistema A Cathering" },
        { "name": "cathering_cafeteria", "description": "Operador cafeteria del Sistema A Cathering" },
        { "name": "cathering_personal_academico", "description": "Personal academico del Sistema A Cathering" }
      ],
      "cathering-backend": [
        { "name": "cathering_admin", "description": "Administrador del Sistema A Cathering" },
        { "name": "cathering_estudiante", "description": "Estudiante del Sistema A Cathering" },
        { "name": "cathering_cafeteria", "description": "Operador cafeteria del Sistema A Cathering" },
        { "name": "cathering_personal_academico", "description": "Personal academico del Sistema A Cathering" }
      ]
    }
  },
  "clients": [
    {
      "clientId": "cathering-react",
      "name": "Sistema A - Cathering React",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect"
    },
    {
      "clientId": "foodies-angular",
      "name": "Sistema B - Foodies Angular",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
